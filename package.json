{
  "name": "@halo-dev/shop-templates",
  "scripts": {
    "build": "vp pack",
    "prettier": "prettier --write .",
    "prepare": "vp config"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "endOfLine": "lf",
    "plugins": [
      "prettier-plugin-svelte",
      "prettier-plugin-organize-imports"
    ],
    "printWidth": 100,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "overrides": [
      {
        "files": "*.svelte",
        "options": {
          "parser": "svelte"
        }
      }
    ]
  },
  "dependencies": {
    "@halo-dev/shop-ui": "workspace:*",
    "medium-zoom": "^1.1.0",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@tsdown/css": "^0.21.4",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.1",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
}
